# ================================
# SnipSnap environment variables
# ================================

# PostgreSQL connection string
# Format:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Example:
# postgresql://snipsnap:snipsnap_pw@localhost:5432/snipsnap_db
DATABASE_URL=postgresql://snipsnap:password@localhost:5432/snipsnap_db


# ================================
# Database schema initialisation
# ================================

# Optional: path to SQL schema file
# Defaults to ./db.sql if not set
# DB_SQL_PATH=C:\path\to\db.sql


# ================================
# Flask configuration
# ================================

# Flask secret key (required later for sessions/auth)
# Replace with a random string in your real .env
FLASK_SECRET_KEY=change-me-in-real-env


# ================================
# Development settings
# ================================

# Set to 1 for development, 0 for production
FLASK_DEBUG=1
